###############################################################################
# RUSTIKAN — Variables de entorno
#
# LOCAL (desarrollo):  copia este archivo como `.env` y rellena los valores.
# PRODUCCIÓN:          en Forge configura las variables desde el panel.
#
# Valores marcados con ⚠️ DEBEN cambiarse en producción.
###############################################################################

# ── Aplicación ───────────────────────────────────────────────────────────────
APP_NAME=Rustikan
APP_ENV=local                                    # ⚠️ producción: "production"
APP_KEY=                                         # ⚠️ generar con `php artisan key:generate`
APP_DEBUG=true                                   # ⚠️ producción: "false" SIEMPRE
APP_URL=http://localhost                         # ⚠️ producción: "https://rustikan.com"

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                                  # ⚠️ producción: "warning" o "error"

# ── Base de datos (MySQL) ────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rustikan
DB_USERNAME=root                                 # ⚠️ producción: usuario dedicado, NO root
DB_PASSWORD=                                     # ⚠️ producción: contraseña fuerte

# ── Sesiones ─────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null                              # ⚠️ producción: ".rustikan.com" (con punto)
SESSION_SECURE_COOKIE=false                      # ⚠️ producción: "true" (requiere HTTPS)
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

# ── Cache / Queues / Broadcast ───────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Redis (opcional, recomendado para producción si tu servidor lo soporta) ──
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Plan gratuito: 3.000 emails/mes. Obtén la API key en https://resend.com
# DESARROLLO: usa `onboarding@resend.dev` como FROM (no requiere dominio verificado).
# PRODUCCIÓN: verifica `rustikan.com` en Resend y usa `noreply@rustikan.com`.
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="onboarding@resend.dev"        # ⚠️ producción: "noreply@rustikan.com"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=                                  # ⚠️ obligatorio (formato: re_xxxxx)

# ── Google reCAPTCHA v2 ──────────────────────────────────────────────────────
# Obtén las claves en https://www.google.com/recaptcha/admin
# Importante: registra TANTO localhost como tu dominio de producción.
RECAPTCHA_SITE_KEY=                              # ⚠️ obligatorio
RECAPTCHA_SECRET_KEY=                            # ⚠️ obligatorio

# ── Google Gemini (Chat IA) ──────────────────────────────────────────────────
# Tier gratuito generoso. Crea la API key en https://aistudio.google.com/apikey
# Modelo recomendado: gemini-2.5-flash (rápido y barato).
GEMINI_API_KEY=                                  # vacío => el chat mostrará un mensaje informativo
GEMINI_MODEL=gemini-2.5-flash

# ── Storage S3 / Cloudflare R2 (opcional, para imágenes en producción) ───────
# Si dejas vacío, las imágenes se guardan en /storage/app/public del servidor.
# Para escalar a múltiples servidores o reducir uso de disco, configura R2/S3.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Cloudflare (proxy/CDN delante del servidor) ──────────────────────────────
# Si pones Cloudflare delante del servidor, deja "*" para confiar en cualquier proxy
# (Forge ya confía en proxies por defecto). Si no usas Cloudflare, comenta esta línea.
TRUSTED_PROXIES=*

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
